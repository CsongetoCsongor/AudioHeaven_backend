@baseUrl = http://localhost:8000/api
@baseUrlServer = https://jcloud02.jedlik.eu/csongeto.csongor/public/api
@authToken = {{login.response.body.token}}

### Login
# @name login
POST {{baseUrl}}/login
Accept: application/json
Content-Type: application/json

{
    "email": "csongeto.csongor@students.jedlik.eu",
    "password": "password"
}

###

### Get user by id
GET {{baseUrl}}/users/3
Accept: application/json

###

### Delete own profile
DELETE {{baseUrl}}/user
Authorization: Bearer {{authToken}}
Accept: application/json

###

### Delete user profile by admin
DELETE {{baseUrl}}/admin/users/7
Authorization: Bearer {{authToken}}
Accept: application/json

###

### My profile data
GET {{baseUrl}}/me
Accept: application/json
Authorization: Bearer {{authToken}}

###

### Search users
GET {{baseUrl}}/users?search=Teszt
Accept: application/json

###

### Get a given amount of random users
GET {{baseUrl}}/users/random?count=2
Accept: application/json

###

### Modify user
POST {{baseUrl}}/user
Authorization: Bearer {{authToken}}
Accept: application/json
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="profile_picture"; filename="pfp.jpg"
Content-Type: image/jpeg

< ./pfp.jpg
--boundary--

###
