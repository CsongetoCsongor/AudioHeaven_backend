@baseUrl = http://localhost:8000/api
@baseUrlServer = https://jcloud02.jedlik.eu/csongeto.csongor/public/api
@authToken = {{login.response.body.token}}


### Registration
POST {{baseUrl}}/register
Accept: application/json
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="username"

Cs Cs
--boundary
Content-Disposition: form-data; name="email"

csongeto.csongor@students.jedlik.eu
--boundary
Content-Disposition: form-data; name="password"

password
--boundary
Content-Disposition: form-data; name="profile_picture"; filename="cover.jpg"
Content-Type: image/png

< ./cover.jpg
--boundary--

###

### Login
# @name login
POST {{baseUrl}}/login
Accept: application/json
Content-Type: application/json

{
    "email": "csongeto.csongor@students.jedlik.eu",
    "password": "password"
}

###

### Logout
POST {{baseUrl}}/logout
Accept: application/json
Authorization: Bearer {{authToken}}

###

### Request reset link
POST {{baseUrl}}/forgot-password
Content-Type: application/json
Accept: application/json

{
    "email": "csongeto.csongor@students.jedlik.eu"
}

### Modify password (copy token from email response)
POST {{baseUrl}}/reset-password
Content-Type: application/json
Accept: application/json

{
    "token": "3dd66eaa75514d8e67528c9c9bfd701bc441a173708b89cc9155c95ac9c5d9fc",
    "password": "uj_jelszo_123",
    "password_confirmation": "uj_jelszo_123"
}
